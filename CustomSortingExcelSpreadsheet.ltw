        <ScriptVariable>
            <Name>in_rangeTableSort</Name>
            <Group>InputData</Group>
            <Comment>Диапазон таблицы для сортировки</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_sheetInputTable</Name>
            <Group>InputData</Group>
            <Comment>Название листа, на котором находится таблица</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_pathExcelFileInputTable</Name>
            <Group>InputData</Group>
            <Comment>Путь к Excel файлу со входной таблицей </Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_rangeInsertingSortedTable</Name>
            <Group>OutputData</Group>
            <Comment>Диапазон для вставки отсортированной таблицы</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_nameSheetInsertingTable</Name>
            <Group>OutputData</Group>
            <Comment>Название листа для вставки отсортированной таблицы</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_pathExcelFileInsertTable</Name>
            <Group>OutputData</Group>
            <Comment>Путь к Excel файлу для вставки таблицы</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_customSortingOrder</Name>
            <Group />
            <DefaultValue xsi:type="xsd:string">new List&lt;String&gt;()</DefaultValue>
            <Comment>Лист с кастомным порядком сортировки</Comment>
            <DataTypeString>List&lt;String&gt;</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_columnNumber</Name>
            <Group>InputData</Group>
            <Comment>Номер колонки для сортировки таблицы</Comment>
            <DataTypeString>Int32</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_columnCellSorting</Name>
            <Group />
            <Comment>Ячейка столбца для сортировки</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
    </Arguments>
    <UseCustomDiagramConnectorFormat>false</UseCustomDiagramConnectorFormat>
</SerializationRoot>